---
// Solox Tek — one-page site. Static, no framework runtime.
// Self-hosted fonts (bundled by Astro) — replaces render-blocking Google Fonts.
import '@fontsource-variable/sora';
import '@fontsource-variable/manrope';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Solox Tek · AI automation that survives production</title>
  <meta name="description" content="Solox Tek builds AI automation that survives production. A senior engineering team with over a decade of production experience: reliable, secure, and made to scale." />
  <link rel="icon" type="image/png" href="/logo-icon.png" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Solox Tek · AI automation that survives production" />
  <meta property="og:description" content="Solox Tek builds AI automation that survives production. A senior engineering team with over a decade of production experience: reliable, secure, and made to scale." />
  <meta property="og:image" content="/og.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <style is:global>
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{margin:0;background:#06121E;color:#EEF4FB;font-family:'Manrope Variable',system-ui,sans-serif;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;}
::selection{background:rgba(54,169,230,0.32);color:#fff;}
a{color:inherit;text-decoration:none;}
@keyframes sxDrift1{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(40px,-30px) scale(1.12)}}
@keyframes sxDrift2{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-46px,28px) scale(1.08)}}
@keyframes sxDrift3{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(24px,34px) scale(1.15)}}
@keyframes sxFloatB{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
@keyframes sxPulseB{0%,100%{opacity:.35}50%{opacity:1}}
@keyframes sxBobB{0%,100%{transform:translateY(0);opacity:.5}50%{transform:translateY(8px);opacity:1}}
@keyframes sxDash{to{stroke-dashoffset:-28}}
.hx0:hover{background:rgba(54,169,230,0.22) !important;box-shadow:0 0 26px rgba(54,169,230,0.4) !important;transform:translateY(-2px) !important;}
.hx1:hover{transform:translateY(-3px) !important;box-shadow:0 0 0 1px rgba(143,224,255,0.4) inset,0 22px 56px rgba(27,124,192,0.62) !important;}
.hx2:hover{border-color:rgba(143,224,255,0.55) !important;background:rgba(255,255,255,0.05) !important;transform:translateY(-3px) !important;}
.hx3:hover{border-color:rgba(143,224,255,0.4) !important;transform:translateY(-4px) !important;box-shadow:0 30px 60px rgba(0,0,0,0.32) !important;}
.hx4:hover{border-color:rgba(143,224,255,0.4) !important;transform:translateY(-4px) !important;box-shadow:0 30px 60px rgba(0,0,0,0.32) !important;}
.hx5:hover{transform:translateY(-3px) !important;box-shadow:0 0 0 1px rgba(143,224,255,0.4) inset,0 24px 62px rgba(27,124,192,0.66) !important;}
  </style>
</head>
<body>
<div id="sb-root" data-screen-label="Solox Tek" style="--sx-accent:#36A9E6;--sx-aurora:1;--sx-pad:clamp(84px,11vw,160px);--sx-grid:1;position:relative;background:#06121E;overflow:hidden;">

  <!-- aurora field -->
  <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;opacity:var(--sx-aurora,1);overflow:hidden;">
    <div data-orb="0.12" style="position:absolute;top:-8%;left:-6%;width:52vw;height:52vw;max-width:720px;max-height:720px;border-radius:50%;background:radial-gradient(circle,rgba(54,169,230,0.34),transparent 64%);filter:blur(26px);animation:sxDrift1 19s ease-in-out infinite;"></div>
    <div data-orb="0.2" style="position:absolute;top:2%;right:-10%;width:46vw;height:46vw;max-width:640px;max-height:640px;border-radius:50%;background:radial-gradient(circle,rgba(47,200,200,0.22),transparent 66%);filter:blur(30px);animation:sxDrift2 23s ease-in-out infinite;"></div>
    <div data-orb="0.16" style="position:absolute;top:46%;left:30%;width:50vw;height:50vw;max-width:680px;max-height:680px;border-radius:50%;background:radial-gradient(circle,rgba(70,120,235,0.2),transparent 65%);filter:blur(34px);animation:sxDrift3 27s ease-in-out infinite;"></div>
  </div>

  <!-- blueprint grid -->
  <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;opacity:var(--sx-grid,1);background-image:linear-gradient(rgba(140,175,215,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(140,175,215,0.05) 1px,transparent 1px);background-size:54px 54px;mask-image:linear-gradient(180deg,#000,#000 68%,transparent);-webkit-mask-image:linear-gradient(180deg,#000,#000 68%,transparent);"></div>

  <!-- NAV -->
  <nav id="sb-nav" style="position:fixed;top:0;left:0;right:0;z-index:60;display:flex;align-items:center;justify-content:space-between;padding:17px clamp(18px,5vw,48px);border-bottom:1px solid rgba(150,180,215,0);transition:background .35s ease,border-color .35s ease,backdrop-filter .35s ease;">
    <a href="#top" style="display:flex;align-items:center;gap:12px;">
      <img src="/logo-icon.webp" alt="Solox Tek" width="30" height="30" style="display:block;width:30px;height:30px;">
      <span style="font-family:'Sora Variable',sans-serif;font-weight:600;font-size:16.5px;letter-spacing:0.16em;color:#EEF4FB;">SOLOX&nbsp;TEK</span>
    </a>
    <a href="mailto:hello@solox-tek.com?subject=Discovery%20call" class="hx0" style="display:inline-flex;align-items:center;gap:8px;padding:11px 22px;border-radius:999px;border:1px solid rgba(54,169,230,0.5);background:rgba(54,169,230,0.1);color:#DCECF8;font-family:'Sora Variable',sans-serif;font-weight:500;font-size:14px;letter-spacing:.01em;transition:background .3s ease,box-shadow .3s ease,transform .3s ease;">Book a call</a>
  </nav>

  <!-- HERO -->
  <header id="top" style="position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:140px clamp(20px,5vw,48px) 100px;">
    <div aria-hidden="true" style="position:absolute;inset:0;overflow:hidden;mask-image:radial-gradient(120% 95% at 50% 42%,#000 42%,transparent 82%);-webkit-mask-image:radial-gradient(120% 95% at 50% 42%,#000 42%,transparent 82%);opacity:.7;">
      <canvas id="sb-net" style="position:absolute;inset:0;display:block;"></canvas>
    </div>
    <div style="position:relative;z-index:2;max-width:1000px;">
      <h1 style="font-family:'Sora Variable',sans-serif;font-weight:300;font-size:clamp(42px,7.6vw,96px);line-height:1.04;letter-spacing:-0.035em;margin:0 0 30px;color:#F5FAFE;">AI automation that<br><span style="font-weight:600;background:linear-gradient(110deg,#8FE0FF,var(--sx-accent,#36A9E6) 55%,#5BC7C0);-webkit-background-clip:text;background-clip:text;color:transparent;">survives production.</span></h1>
      <p style="font-family:'Manrope Variable',sans-serif;font-weight:400;font-size:clamp(17px,1.55vw,21px);line-height:1.66;color:#AEC4DC;max-width:60ch;margin:0 auto 42px;">A senior engineering team with over a decade of production experience. We build automation you actually own: reliable, secure, and made to scale. Not a black box that breaks the moment your business changes.</p>
      <div style="display:flex;flex-wrap:wrap;gap:15px;justify-content:center;">
        <a href="mailto:hello@solox-tek.com?subject=Free%20discovery%20call" class="hx1" style="display:inline-flex;align-items:center;gap:10px;padding:16px 32px;border-radius:14px;background:linear-gradient(180deg,var(--sx-accent,#36A9E6),#1B7CC0);color:#fff;font-family:'Sora Variable',sans-serif;font-weight:600;font-size:16px;box-shadow:0 0 0 1px rgba(143,224,255,0.25) inset,0 16px 44px rgba(27,124,192,0.46);transition:transform .25s ease,box-shadow .25s ease;">Book a free discovery call</a>
        <a href="#process" class="hx2" style="display:inline-flex;align-items:center;gap:9px;padding:16px 28px;border-radius:14px;border:1px solid rgba(150,180,215,0.26);background:rgba(255,255,255,0.02);color:#D6E4F2;font-family:'Sora Variable',sans-serif;font-weight:500;font-size:16px;transition:border-color .25s ease,background .25s ease,transform .25s ease;">See how we work <span style="color:var(--sx-accent,#36A9E6);">→</span></a>
      </div>
      <div style="margin-top:54px;display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:12px 26px;font-family:'Sora Variable',sans-serif;font-size:13px;font-weight:500;letter-spacing:0.04em;color:#7E97B4;">
        <span style="color:#A6BDD6;">10+ years in production</span>
        <span style="width:4px;height:4px;border-radius:50%;background:rgba(54,169,230,0.6);"></span>
        <span style="color:#A6BDD6;">You own the code</span>
      </div>
    </div>
    <div aria-hidden="true" style="position:absolute;left:50%;bottom:28px;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;font-family:'Sora Variable',sans-serif;font-size:10px;font-weight:500;letter-spacing:0.34em;color:#5E7895;animation:sxBobB 2.6s ease-in-out infinite;">
      <span>SCROLL</span>
      <span style="width:1px;height:26px;background:linear-gradient(#5E7895,transparent);"></span>
    </div>
  </header>

  <!-- PROBLEM -->
  <section id="problem" style="position:relative;padding:var(--sx-pad,clamp(84px,11vw,160px)) clamp(20px,5vw,48px);">
    <div style="max-width:1120px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:clamp(36px,5vw,72px);align-items:center;">
        <div data-reveal>
          <h2 style="font-family:'Sora Variable',sans-serif;font-weight:300;font-size:clamp(30px,4.4vw,54px);line-height:1.08;letter-spacing:-0.025em;margin:0 0 24px;color:#F5FAFE;">Your team is doing work <span style="font-weight:600;">software should do.</span></h2>
          <p style="font-family:'Manrope Variable',sans-serif;font-size:clamp(16px,1.3vw,18.5px);line-height:1.74;color:#A6BCD6;margin:0;max-width:54ch;">Most teams lose hours every day moving data around by hand, entering the same thing into three different tools, and waiting on approvals that could run on their own. The tools don't talk to each other, and the quick automations bolted on top tend to fall apart the moment real volume shows up.</p>
        </div>
        <div data-reveal style="position:relative;border-radius:26px;background:linear-gradient(160deg,rgba(230,162,60,0.07),rgba(12,26,44,0.2));border:1px solid rgba(150,180,215,0.1);padding:44px 34px;backdrop-filter:blur(4px);">
          <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:13px;margin-bottom:24px;">
            <div style="animation:sxFloatB 6s ease-in-out infinite;animation-delay:0s;font-family:'Sora Variable',sans-serif;font-weight:500;font-size:13.5px;color:#D2E0EE;padding:13px 20px;border-radius:13px;border:1px solid rgba(230,162,60,0.38);background:rgba(230,162,60,0.05);">Email</div>
            <div style="animation:sxFloatB 6s ease-in-out infinite;animation-delay:-1.5s;font-family:'Sora Variable',sans-serif;font-weight:500;font-size:13.5px;color:#D2E0EE;padding:13px 20px;border-radius:13px;border:1px solid rgba(230,162,60,0.38);background:rgba(230,162,60,0.05);">Database</div>
            <div style="animation:sxFloatB 6s ease-in-out infinite;animation-delay:-3s;font-family:'Sora Variable',sans-serif;font-weight:500;font-size:13.5px;color:#D2E0EE;padding:13px 20px;border-radius:13px;border:1px solid rgba(230,162,60,0.38);background:rgba(230,162,60,0.05);">Docs</div>
            <div style="animation:sxFloatB 6s ease-in-out infinite;animation-delay:-4.5s;font-family:'Sora Variable',sans-serif;font-weight:500;font-size:13.5px;color:#D2E0EE;padding:13px 20px;border-radius:13px;border:1px solid rgba(230,162,60,0.38);background:rgba(230,162,60,0.05);">CRM</div>
          </div>
          <svg viewBox="0 0 300 70" width="100%" height="60" style="display:block;opacity:.85;margin-bottom:18px;" aria-hidden="true">
            <line x1="20" y1="18" x2="120" y2="52" stroke="#E6A23C" stroke-width="1.4" stroke-dasharray="5 6" stroke-opacity="0.55" style="animation:sxDash 1.6s linear infinite;"></line>
            <line x1="150" y1="14" x2="210" y2="54" stroke="#E6A23C" stroke-width="1.4" stroke-dasharray="5 6" stroke-opacity="0.4" style="animation:sxDash 2.1s linear infinite;"></line>
            <line x1="245" y1="16" x2="160" y2="56" stroke="#E6A23C" stroke-width="1.4" stroke-dasharray="5 6" stroke-opacity="0.3" style="animation:sxDash 2.6s linear infinite;"></line>
            <line x1="60" y1="50" x2="250" y2="22" stroke="#E6A23C" stroke-width="1.4" stroke-dasharray="5 6" stroke-opacity="0.35" style="animation:sxDash 1.9s linear infinite;"></line>
          </svg>
          <div style="text-align:center;font-family:'Sora Variable',sans-serif;font-size:11.5px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#E6A23C;">scattered &nbsp;·&nbsp; manual &nbsp;·&nbsp; disconnected</div>
        </div>
      </div>
    </div>
  </section>

  <!-- COST -->
  <section id="cost" style="position:relative;padding:0 clamp(20px,5vw,48px) var(--sx-pad,clamp(84px,11vw,160px));">
    <div data-reveal style="max-width:1120px;margin:0 auto;text-align:center;">
      <div style="display:flex;align-items:baseline;justify-content:center;gap:4px;line-height:1;">
        <span id="sb-stat" data-target="20" style="font-family:'Sora Variable',sans-serif;font-weight:700;font-size:clamp(96px,18vw,228px);letter-spacing:-0.05em;background:linear-gradient(180deg,#F6C775,#E6A23C);-webkit-background-clip:text;background-clip:text;color:transparent;">20</span>
        <span style="font-family:'Sora Variable',sans-serif;font-weight:700;font-size:clamp(44px,8vw,104px);color:#E6A23C;letter-spacing:-0.03em;">%+</span>
      </div>
      <div style="font-family:'Sora Variable',sans-serif;font-weight:400;font-size:clamp(15px,1.4vw,19px);letter-spacing:0.02em;color:#B9C9DC;margin:6px 0 30px;">of every work week lost to repetitive manual tasks</div>
      <h2 style="font-family:'Sora Variable',sans-serif;font-weight:300;font-size:clamp(26px,3.6vw,46px);line-height:1.1;letter-spacing:-0.025em;margin:0 auto 20px;color:#F5FAFE;max-width:20ch;">Manual work quietly <span style="font-weight:600;">eats your week.</span></h2>
      <p style="font-family:'Manrope Variable',sans-serif;font-size:clamp(16px,1.3vw,18.5px);line-height:1.72;color:#A6BCD6;margin:0 auto;max-width:62ch;">On top of that come the errors that reach customers and the automations someone still has to babysit. That's real time and money walking out the door, and it scales your problems, not your output.</p>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section id="what" style="position:relative;padding:var(--sx-pad,clamp(84px,11vw,160px)) clamp(20px,5vw,48px);">
    <div style="max-width:1120px;margin:0 auto;">
      <div data-reveal style="text-align:center;max-width:780px;margin:0 auto clamp(46px,5vw,72px);">
        <h2 style="font-family:'Sora Variable',sans-serif;font-weight:300;font-size:clamp(30px,4.6vw,56px);line-height:1.07;letter-spacing:-0.03em;margin:0;color:#F5FAFE;">Scalable AI automation that <span style="font-weight:600;">holds up in production.</span></h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;">
        <div data-reveal class="hx3" style="border-radius:24px;border:1px solid rgba(150,180,215,0.12);background:linear-gradient(120deg,rgba(20,42,68,0.45),rgba(10,22,38,0.2));padding:clamp(30px,3.5vw,44px);transition:border-color .35s ease,transform .35s ease,box-shadow .35s ease;">
          <div style="display:flex;gap:5px;margin-bottom:24px;">
            <span style="width:11px;height:11px;border-radius:3px;background:var(--sx-accent,#36A9E6);"></span>
            <span style="width:11px;height:11px;border-radius:3px;background:rgba(143,224,255,0.45);"></span>
            <span style="width:11px;height:11px;border-radius:3px;background:rgba(143,224,255,0.2);"></span>
          </div>
          <h3 style="font-family:'Sora Variable',sans-serif;font-weight:600;font-size:clamp(21px,2.1vw,28px);letter-spacing:-0.01em;margin:0 0 14px;color:#F5FAFE;">Ops &amp; document automation</h3>
          <p style="font-family:'Manrope Variable',sans-serif;font-size:clamp(15.5px,1.3vw,18px);line-height:1.68;color:#A6BCD6;margin:0;">We connect your tools, automate repetitive processes, and add AI where it removes real work: document processing, data extraction, routing, and reporting.</p>
        </div>
        <div data-reveal class="hx4" style="border-radius:24px;border:1px solid rgba(150,180,215,0.12);background:linear-gradient(120deg,rgba(20,42,68,0.45),rgba(10,22,38,0.2));padding:clamp(30px,3.5vw,44px);transition:border-color .35s ease,transform .35s ease,box-shadow .35s ease;">
          <div style="display:flex;gap:5px;margin-bottom:24px;">
            <span style="width:11px;height:11px;border-radius:3px;background:var(--sx-accent,#36A9E6);"></span>
            <span style="width:11px;height:11px;border-radius:3px;background:rgba(143,224,255,0.45);"></span>
            <span style="width:11px;height:11px;border-radius:3px;background:rgba(143,224,255,0.2);"></span>
          </div>
          <h3 style="font-family:'Sora Variable',sans-serif;font-weight:600;font-size:clamp(21px,2.1vw,28px);letter-spacing:-0.01em;margin:0 0 14px;color:#F5FAFE;">GTM &amp; revenue automation</h3>
          <p style="font-family:'Manrope Variable',sans-serif;font-size:clamp(15.5px,1.3vw,18px);line-height:1.68;color:#A6BCD6;margin:0;">We automate your pipeline end to end: capturing leads, enrichment, scoring, personalized outreach, CRM sync, and follow up, with our GTM specialists shaping the strategy.</p>
        </div>
      </div>
      <p data-reveal style="text-align:center;font-family:'Manrope Variable',sans-serif;font-size:clamp(15px,1.3vw,18px);line-height:1.6;color:#92A9C6;margin:30px auto 0;max-width:70ch;">Built like real software. Owned end to end, and made to scale.</p>
    </div>
  </section>

  <!-- WHY US -->
  <section id="why" style="position:relative;padding:0 clamp(20px,5vw,48px) var(--sx-pad,clamp(84px,11vw,160px));">
    <div style="max-width:1120px;margin:0 auto;">
      <div data-reveal style="max-width:820px;margin:0 auto clamp(44px,5vw,66px);text-align:center;">
        <h2 style="font-family:'Sora Variable',sans-serif;font-weight:300;font-size:clamp(30px,4.6vw,56px);line-height:1.07;letter-spacing:-0.03em;margin:0 0 22px;color:#F5FAFE;">Engineered, <span style="font-weight:600;">not vibe coded.</span></h2>
        <p style="font-family:'Manrope Variable',sans-serif;font-size:clamp(16px,1.3vw,18.5px);line-height:1.72;color:#A6BCD6;margin:0 auto;max-width:64ch;">Most AI automation out there is held together with duct tape and falls apart under load. We're a senior engineering team with over a decade of production experience. Code you own, instead of a black box that breaks the moment your business changes.</p>
      </div>
      <div data-reveal style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:0;border-top:1px solid rgba(150,180,215,0.14);">
        <div style="padding:34px clamp(18px,2.5vw,34px);border-right:1px solid rgba(150,180,215,0.1);">
          <div style="font-family:'Sora Variable',sans-serif;font-weight:500;font-size:12px;letter-spacing:0.2em;text-transform:uppercase;color:var(--sx-accent,#36A9E6);margin-bottom:18px;">01</div>
          <h3 style="font-family:'Sora Variable',sans-serif;font-weight:600;font-size:clamp(20px,2vw,25px);margin:0 0 12px;color:#F5FAFE;">Reliability</h3>
          <p style="font-family:'Manrope Variable',sans-serif;font-size:16px;line-height:1.62;color:#9FB6D0;margin:0;">Real error handling, not just the happy path.</p>
        </div>
        <div style="padding:34px clamp(18px,2.5vw,34px);border-right:1px solid rgba(150,180,215,0.1);">
          <div style="font-family:'Sora Variable',sans-serif;font-weight:500;font-size:12px;letter-spacing:0.2em;text-transform:uppercase;color:var(--sx-accent,#36A9E6);margin-bottom:18px;">02</div>
          <h3 style="font-family:'Sora Variable',sans-serif;font-weight:600;font-size:clamp(20px,2vw,25px);margin:0 0 12px;color:#F5FAFE;">Security</h3>
          <p style="font-family:'Manrope Variable',sans-serif;font-size:16px;line-height:1.62;color:#9FB6D0;margin:0;">Safe by design, drawn from our DeFi work.</p>
        </div>
        <div style="padding:34px clamp(18px,2.5vw,34px);">
          <div style="font-family:'Sora Variable',sans-serif;font-weight:500;font-size:12px;letter-spacing:0.2em;text-transform:uppercase;color:var(--sx-accent,#36A9E6);margin-bottom:18px;">03</div>
          <h3 style="font-family:'Sora Variable',sans-serif;font-weight:600;font-size:clamp(20px,2vw,25px);margin:0 0 12px;color:#F5FAFE;">You own the code</h3>
          <p style="font-family:'Manrope Variable',sans-serif;font-size:16px;line-height:1.62;color:#9FB6D0;margin:0;">No black box, nothing locked in.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section id="process" style="position:relative;padding:var(--sx-pad,clamp(84px,11vw,160px)) clamp(20px,5vw,48px);">
    <div style="max-width:1120px;margin:0 auto;">
      <div data-reveal style="text-align:center;max-width:800px;margin:0 auto clamp(48px,5vw,72px);">
        <h2 style="font-family:'Sora Variable',sans-serif;font-weight:300;font-size:clamp(30px,4.6vw,56px);line-height:1.07;letter-spacing:-0.03em;margin:0;color:#F5FAFE;">Our process, and how an <span style="font-weight:600;">engagement runs.</span></h2>
      </div>
