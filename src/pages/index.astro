  <script is:inline>
(function(){
  function init(){
    let _cleanup; let rafStat;

    _cleanup = [];
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- Nav scroll state ----
    const nav = document.getElementById('sb-nav');
    const onScroll = () => {
      if (!nav) return;
      const s = window.scrollY > 24;
      nav.style.background = s ? 'rgba(6,18,30,0.78)' : 'rgba(6,18,30,0)';
      nav.style.borderBottomColor = s ? 'rgba(150,180,215,0.13)' : 'rgba(150,180,215,0)';
      nav.style.backdropFilter = s ? 'blur(16px)' : 'none';
      nav.style.webkitBackdropFilter = s ? 'blur(16px)' : 'none';
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
    _cleanup.push(() => window.removeEventListener('scroll', onScroll));

    // ---- Scroll reveals (fade + rise + slight scale) ----
    if (!reduce && 'IntersectionObserver' in window) {
      const reveals = [...document.querySelectorAll('[data-reveal]')];
      reveals.forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(34px) scale(0.985)';
        el.style.transition = 'opacity 1s cubic-bezier(.2,.7,.2,1), transform 1s cubic-bezier(.2,.7,.2,1)';
      });
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.style.opacity = '1';
            e.target.style.transform = 'none';
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      reveals.forEach(el => io.observe(el));
      _cleanup.push(() => io.disconnect());
    }

    // ---- Stat counter ----
    const stat = document.getElementById('sb-stat');
    if (stat) {
      const target = parseFloat(stat.getAttribute('data-target')) || 0;
      let started = false;
      const run = () => {
        if (started) return; started = true;
        if (reduce) { stat.textContent = String(target); return; }
        const dur = 1600, t0 = performance.now();
        const tick = (now) => {
          const p = Math.min(1, (now - t0) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          stat.textContent = Math.round(target * eased).toString();
          if (p < 1) rafStat = requestAnimationFrame(tick);
        };
        rafStat = requestAnimationFrame(tick);
      };
      const io2 = new IntersectionObserver((ents) => {
        ents.forEach(e => { if (e.isIntersecting) { run(); io2.unobserve(e.target); } });
      }, { threshold: 0.6 });
      io2.observe(stat);
      _cleanup.push(() => io2.disconnect());
    }

    // ---- Parallax (mouse in hero + scroll) on aurora orbs ----
    if (!reduce) {
      const orbs = [...document.querySelectorAll('[data-orb]')];
      let mx = 0, my = 0, sy = 0, ticking = false;
      const apply = () => {
        ticking = false;
        orbs.forEach(o => {
          const k = parseFloat(o.getAttribute('data-orb')) || 0.1;
          o.style.marginLeft = (mx * k * 60) + 'px';
          o.style.marginTop = ((my * k * 60) + (sy * k * 0.25)) + 'px';
        });
      };
      const req = () => { if (!ticking) { ticking = true; requestAnimationFrame(apply); } };
      const onMove = (e) => {
        mx = (e.clientX / window.innerWidth) - 0.5;
        my = (e.clientY / window.innerHeight) - 0.5;
        req();
      };
      const onScr = () => { sy = window.scrollY; req(); };
      window.addEventListener('pointermove', onMove, { passive: true });
      window.addEventListener('scroll', onScr, { passive: true });
      _cleanup.push(() => { window.removeEventListener('pointermove', onMove); window.removeEventListener('scroll', onScr); });
    }

    // ---- Hero node network ----
    const canvas = document.getElementById('sb-net');
    if (canvas && canvas.getContext) {
      const ctx = canvas.getContext('2d');
      const wrap = canvas.parentElement;
      const hexToRgb = (hex) => {
        const m = (hex || '').trim().replace('#', '');
        if (m.length < 6) return [120, 200, 245];
        return [parseInt(m.slice(0,2),16), parseInt(m.slice(2,4),16), parseInt(m.slice(4,6),16)];
      };
      const rootEl = document.getElementById('sb-root');
      const av = rootEl ? getComputedStyle(rootEl).getPropertyValue('--sx-accent') : '';
      const rgb = hexToRgb(av || '#5BC7FF');
      const C = rgb.join(',');
      let w = 0, h = 0, dpr = 1, nodes = [], packets = [], raf = 0;
      const COUNT = 46, DIST = 152;
      const resize = () => {
        dpr = Math.min(2, window.devicePixelRatio || 1);
        w = wrap.clientWidth; h = wrap.clientHeight;
        canvas.width = Math.max(1, w * dpr); canvas.height = Math.max(1, h * dpr);
        canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      };
      const init = () => {
        nodes = [];
        const n = Math.min(COUNT, Math.round((w * h) / 26000));
        for (let i = 0; i < n; i++) {
          nodes.push({ x: Math.random()*w, y: Math.random()*h, vx:(Math.random()-.5)*0.22, vy:(Math.random()-.5)*0.22, s: Math.random()*2+1.6 });
        }
        packets = [];
      };
      const draw = () => {
        ctx.clearRect(0, 0, w, h);
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i+1; j < nodes.length; j++) {
            const a = nodes[i], b = nodes[j];
            const dx = a.x-b.x, dy = a.y-b.y, dd = Math.hypot(dx, dy);
            if (dd < DIST) {
              const op = (1 - dd/DIST) * 0.26;
              ctx.strokeStyle = 'rgba(' + C + ',' + op + ')';
              ctx.lineWidth = 1;
              ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
            }
          }
        }
        for (const nd of nodes) {
          ctx.fillStyle = 'rgba(' + C + ',0.65)';
          ctx.fillRect(nd.x - nd.s/2, nd.y - nd.s/2, nd.s, nd.s);
        }
        if (!reduce && Math.random() < 0.05 && packets.length < 12) {
          const a = nodes[(Math.random()*nodes.length)|0];
          let cand = null, best = DIST;
          for (const b of nodes) { if (b === a) continue; const dd = Math.hypot(a.x-b.x, a.y-b.y); if (dd < best) { best = dd; cand = b; } }
          if (cand) packets.push({ a, b: cand, t: 0, sp: 0.011 + Math.random()*0.02 });
        }
        for (let k = packets.length-1; k >= 0; k--) {
          const p = packets[k]; p.t += p.sp;
          if (p.t >= 1) { packets.splice(k, 1); continue; }
          const x = p.a.x + (p.b.x - p.a.x) * p.t, y = p.a.y + (p.b.y - p.a.y) * p.t;
          ctx.fillStyle = 'rgba(' + C + ',0.95)';
          ctx.beginPath(); ctx.arc(x, y, 2.3, 0, Math.PI*2); ctx.fill();
          ctx.fillStyle = 'rgba(' + C + ',0.16)';
          ctx.beginPath(); ctx.arc(x, y, 7, 0, Math.PI*2); ctx.fill();
        }
      };
      const step = () => {
        for (const nd of nodes) {
          nd.x += nd.vx; nd.y += nd.vy;
          if (nd.x < 0 || nd.x > w) nd.vx *= -1;
          if (nd.y < 0 || nd.y > h) nd.vy *= -1;
          nd.x = Math.max(0, Math.min(w, nd.x)); nd.y = Math.max(0, Math.min(h, nd.y));
        }
        draw();
        raf = requestAnimationFrame(step);
      };
      resize(); init();
      if (reduce) draw(); else step();
      let rt;
      const onR = () => { clearTimeout(rt); rt = setTimeout(() => { resize(); init(); if (reduce) draw(); }, 180); };
      window.addEventListener('resize', onR);
      _cleanup.push(() => { cancelAnimationFrame(raf); clearTimeout(rt); window.removeEventListener('resize', onR); });
    }
  
  }
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
})();
  </script>
